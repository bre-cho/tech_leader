# ============================================================
# .env.example — local development environment variables
# Copy to .env and fill in values for your local setup.
# DO NOT commit real secrets to source control.
# ============================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://kol:kol@localhost:5432/kol

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Provider API keys (fill at least one for local testing) ──────────────────
VEO_API_KEY=
VEO_PROJECT_ID=
RUNWAY_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
SEEDANCE_API_KEY=
SEEDANCE2_API_KEY=

# ── Audio / TTS ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── LLM backends ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── Publish providers ─────────────────────────────────────────────────────────
PUBLISH_PROVIDER_MODE=SIMULATED          # set to youtube/tiktok/meta in production
YOUTUBE_API_KEY=
TIKTOK_OAUTH_CLIENT_ID=
TIKTOK_OAUTH_CLIENT_SECRET=
META_ACCESS_TOKEN=

# ── Avatar embedding ─────────────────────────────────────────────────────────
# Remote model endpoint (preferred) or leave blank to use local CLIP.
MEDIA_EMBEDDING_MODEL_ENDPOINT=
# Allow SHA-256 stub fallback in dev (never set true in production).
ALLOW_AVATAR_EMBEDDING_STUB=true

# ── Drama ML models ───────────────────────────────────────────────────────────
# Leave blank to use heuristic fallback; fill with trained artifact paths.
DRAMA_TENSION_MODEL_PATH=
DRAMA_SUBTEXT_MODEL_PATH=
DRAMA_INTENT_MODEL_PATH=
DRAMA_MEMORY_RECALL_MODEL_PATH=

# ── Drama TTS ─────────────────────────────────────────────────────────────────
DRAMA_TTS_ENABLED=false                  # set true when ElevenLabs key is set
DRAMA_TTS_BACKEND=elevenlabs
DRAMA_TTS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Feature flags ─────────────────────────────────────────────────────────────
CAPABILITY_CACHE_TTL_SECONDS=60
# CAPABILITY_OVERRIDES='{"veo": {"quality_bias": 0.90}}'   # optional
